# ─────────────────────────────────────────────────────────────
# iRacing Companion — Local Bridge Configuration
# Copy this file to .env and fill in your values.
# .env is git-ignored — never commit your real keys.
# ─────────────────────────────────────────────────────────────

# ── Team Multi-Driver Relay (optional but required for Team Command page) ──

# Your Supabase project URL (find in Supabase dashboard → Settings → API)
SUPABASE_URL=https://your-project.supabase.co

# Supabase anon/public key (safe to use in the bridge)
SUPABASE_ANON_KEY=your-anon-key-here

# Team session code — share this with all drivers in your team
# Generate one in the Team Command page and paste it here.
# Example: LE-MANS-2026-A
TEAM_CODE=

# Your display name shown on the team wall (defaults to your iRacing username if blank)
DRIVER_NAME=
