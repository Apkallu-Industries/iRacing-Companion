{
  "name": "pit-wall-desktop",
  "version": "1.0.0",
  "description": "Pit Wall Desktop — iRacing telemetry workbench with bundled local bridge.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "prepackage": "node ./scripts/copy-bridge.js",
    "package": "electron-packager . \"Pit Wall\" --platform=win32 --arch=x64 --out=dist --overwrite",
    "postpackage": "node ./scripts/remove-bridge.js"
  },
  "private": true,
  "author": "Pit Wall",
  "license": "UNLICENSED",
  "devDependencies": {
    "@electron/packager": "^20.0.0",
    "electron": "^31.7.7"
  }
}
