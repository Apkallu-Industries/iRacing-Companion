{
  "name": "pit-wall-desktop",
  "version": "1.2.1-alpha",
  "description": "Pit Wall Desktop — iRacing telemetry workbench with bundled local bridge.",
  "main": "main.cjs",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "sync-bridge": "node ./scripts/copy-bridge.js",
    "prestart": "node ./scripts/copy-bridge.js",
    "version:alpha": "node ./scripts/bump-version.js",
    "changelog:update": "node ./scripts/update-changelog.js",
    "dist": "npm run version:alpha && npm run changelog:update && node ./scripts/copy-bridge.js && electron-builder --win --x64",
    "dist:dir": "npm run version:alpha && npm run changelog:update && node ./scripts/copy-bridge.js && electron-builder --win --x64 --dir",
    "dist:portable": "npm run version:alpha && npm run changelog:update && node ./scripts/copy-bridge.js && electron-builder --win --x64 --config.win.target=portable"
  },
  "build": {
    "appId": "industries.apkallu.pitwall",
    "productName": "Pit Wall",
    "copyright": "Copyright © 2025 Apkallu Industries",
    "directories": {
      "buildResources": "assets",
      "output": "dist-installer"
    },
    "files": [
      "main.cjs",
      "preload.cjs",
      "runtimeSupervisor.cjs",
      "package.json",
      "assets/**/*",
      "!node_modules/**",
      "!dist-installer/**",
      "!bridge/**"
    ],
    "extraResources": [
      {
        "from": "bridge",
        "to": "bridge",
        "filter": [
          "**/*",
          "!node_modules/.cache/**"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Pit Wall",
      "runAfterFinish": true,
      "deleteAppDataOnUninstall": false
    },
    "nodeGypRebuild": false,
    "npmRebuild": false
  },
  "engines": {
    "node": "24.13.0"
  },
  "private": true,
  "author": "Apkallu Industries",
  "license": "UNLICENSED",
  "devDependencies": {
    "electron": "31.7.7",
    "electron-builder": "25.1.8"
  }
}
